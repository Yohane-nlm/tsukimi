#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
RES_DIR="$SCRIPT_DIR/../Resources"
SCHEMA_DIR="$RES_DIR/glib-2.0/schemas"
CACHE_DIR="${HOME}/Library/Caches/Tsukimi"
FILTERED_GST_DIR="${CACHE_DIR}/gstreamer-1.0-no-gtk"

if [ -d "$SCHEMA_DIR" ]; then
  export GSETTINGS_SCHEMA_DIR="$SCHEMA_DIR"
fi

FRAMEWORKS_DIR="$SCRIPT_DIR/../Frameworks"
if [ -d "$FRAMEWORKS_DIR" ]; then
  export DYLD_FALLBACK_LIBRARY_PATH="$FRAMEWORKS_DIR${DYLD_FALLBACK_LIBRARY_PATH:+:$DYLD_FALLBACK_LIBRARY_PATH}"
fi

GST_PLUGIN_SRC=""
if [ -d "$RES_DIR/gstreamer-1.0" ]; then
  GST_PLUGIN_SRC="$RES_DIR/gstreamer-1.0"
elif [ -d "/opt/homebrew/lib/gstreamer-1.0" ]; then
  GST_PLUGIN_SRC="/opt/homebrew/lib/gstreamer-1.0"
elif [ -d "/usr/local/lib/gstreamer-1.0" ]; then
  GST_PLUGIN_SRC="/usr/local/lib/gstreamer-1.0"
fi

if [ -n "$GST_PLUGIN_SRC" ]; then
  mkdir -p "$FILTERED_GST_DIR"
  rm -f "$FILTERED_GST_DIR"/*.dylib
  for plugin in "$GST_PLUGIN_SRC"/*.dylib; do
    [ -e "$plugin" ] || continue
    base="$(basename "$plugin")"
    case "$base" in
      libgstgtk*.dylib|libgstpython.dylib)
        continue
        ;;
    esac
    ln -sf "$plugin" "$FILTERED_GST_DIR/$base"
  done

  export GST_PLUGIN_SYSTEM_PATH_1_0=""
  export GST_PLUGIN_PATH_1_0="$FILTERED_GST_DIR"
  export GST_REGISTRY_1_0="${CACHE_DIR}/gstreamer-registry.bin"
  rm -f "$GST_REGISTRY_1_0"
fi

exec "$SCRIPT_DIR/tsukimi-bin" "$@"
